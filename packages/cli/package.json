{
  "name": "@babeli/cli",
  "version": "0.0.2",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "babeli": "dist/main.js"
  },
  "dependencies": {
    "@babeli/core": "workspace:*",
    "@clack/prompts": "^0.11.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/yargs": "^17.0.35",
    "prettier": "^3.8.3"
  },
  "scripts": {
    "build": "bun build src/main.ts --outdir dist --target node",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepublish": "bun run build",
    "publish": "bun publish --access public --production",
    "update": "bun update"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
