{
  "name": "@babeli/ollama",
  "version": "0.0.1",
  "main": "dist/index.js",
  "module": "src/index.ts",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@langchain/ollama": "^0.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/jest": "^30.0.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.4"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepublish": "bun run build",
    "publish": "bun publish --access public --production",
    "test": "bun test"
  },
  "peerDependencies": {
    "@babeli/core": "workspace:*",
    "typescript": "^6.0.3"
  }
}
