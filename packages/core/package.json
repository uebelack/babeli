{
  "name": "@babeli/core",
  "version": "0.0.1",
  "module": "src/index.ts",
  "license": "MIT",
  "type": "module",
  "bin": {
    "babeli": "dist/main.js"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@langchain/core": "^1.1.48",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/jest": "^30.0.0",
    "@types/yargs": "^17.0.33",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.4"
  },
  "scripts": {
    "build": "bun build src/cli/main.ts --outdir dist --target node ",
